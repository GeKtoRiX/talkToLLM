APP_ENV=development
LOG_LEVEL=INFO
ALLOWED_ORIGIN=http://localhost:5173
LLM_PROVIDER=lmstudio
STT_PROVIDER=whisper_rocm
TTS_PROVIDER=kokoro
STT_MODEL_ROOT=models/whisper
STT_MODEL_SIZE=medium.en
STT_DEVICE=auto
STT_COMPUTE_TYPE=int8
STT_BEAM_SIZE=1
STT_LOCAL_FILES_ONLY=false
STT_ALLOW_CPU_FALLBACK=false
STT_TIMEOUT_SECONDS=30         # max seconds to wait for finalize_utterance()
AUDIO_BUFFER_MAX_BYTES=10000000 # 10 MB hard cap per turn; protects against runaway audio
LLM_MODEL=gemma-4-e4b-it
LLM_VISION_MODEL=                    # vision-capable model; when set, receives raw images instead of OCR text
LLM_VISION_BYPASS_OCR=true          # skip external OCR when vision model is active
LLM_TIMEOUT_SECONDS=45
LLM_TEMPERATURE=0.6
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_REASONING_EFFORT=           # "none" disables thinking chain for reasoning models (Qwen3 etc.)
SCREENSHOT_MAX_BYTES=5242880
SCREENSHOT_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/webp
OCR_ENABLED=true
OCR_BACKEND=tesseract
OCR_MODEL_ROOT=models/ocr
OCR_LOCAL_FILES_ONLY=false
OCR_MAX_PATCHES=12
KOKORO_MODEL_ROOT=models/kokoro
KOKORO_LANG_CODE=a
KOKORO_VOICE=af_heart
KOKORO_SPEED=1.0
KOKORO_REPO_ID=hexgrad/Kokoro-82M
KOKORO_DEVICE=cpu
KOKORO_LOCAL_FILES_ONLY=false
ASSISTANT_SYSTEM_PROMPT=You are a concise English-only speaking assistant. Keep answers short and suitable for voice playback.
STUDY_DB_PATH=data/study.sqlite  # vocabulary SRS database; path relative to repo root
