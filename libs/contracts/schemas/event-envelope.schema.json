{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VoiceEventEnvelope",
  "type": "object",
  "required": ["type", "sessionId", "turnId", "seq", "timestamp", "payload"],
  "properties": {
    "type": {
      "type": "string"
    },
    "sessionId": {
      "type": ["string", "null"]
    },
    "turnId": {
      "type": ["string", "null"]
    },
    "seq": {
      "type": "integer",
      "minimum": 0
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {}
  },
  "additionalProperties": false
}
